# Configurações do Client de Impressão

# URL da API (use o domínio da Vercel em produção)
API_URL=

# Credenciais de login (usuário admin do estabelecimento)
USUARIO=
SENHA=

# Intervalo de polling em segundos (quanto tempo entre cada verificação de novos pedidos)
INTERVALO_POLLS=5

# Configuração da Impressora USB
# Use 'lsusb' no Linux ou 'Zadig' no Windows para encontrar os IDs
# Para testar sem impressora (apenas logs), comente ou remova as linhas abaixo
# USB_VENDOR_ID=0x04b8
# USB_PRODUCT_ID=0x0005