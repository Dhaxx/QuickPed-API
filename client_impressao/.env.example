# Configurações do Client de Impressão

# URL da API (use o domínio da Vercel em produção)
API_URL=

# Credenciais de login (usuário admin do estabelecimento)
USUARIO=
SENHA=

# Intervalo de polling em segundos (quanto tempo entre cada verificação de novos pedidos)
INTERVALO_POLLS=5

# ============================================
# Configuração de Impressora
# ============================================
# Escolha uma das opções abaixo:
# 
# OPÇÃO 1: Impressora Windows (Win32Raw) - Recomendado para MPT-II via USB
# Use o nome da impressora instalada no Windows
PRINTER_NAME=

# OPÇÃO 2: Impressora USB (RAW)
# GEZHI micro-printer (MPT-II)
# USB_VENDOR_ID=0x28e9
# USB_PRODUCT_ID=0x0289

# OPÇÃO 3: Impressora Serial (Bluetooth/COM)
# Configure a porta COM (ex: COM3 no Windows, /dev/rfcomm0 no Linux para Bluetooth)
# SERIAL_PORT=COM3
# SERIAL_BAUDRATE=9600